generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Product {
  id           String        @id @default(uuid())
  name         String
  category     String
  unit         String
  costPrice    Float
  sellingPrice Float
  stock        Int
  createdAt    DateTime      @default(now())

  rateHistory  RateHistory[]
  purchases    Purchase[]
  sales        Sale[]
}

model Purchase {
  id            String   @id @default(uuid())
  product       Product  @relation(fields: [productId], references: [id])
  productId     String
  quantity      Int
  cost          Float
  supplier      String
  transportCost Float
  totalCost     Float
  date          DateTime @default(now())
}

model Sale {
  id           String   @id @default(uuid())
  product      Product  @relation(fields: [productId], references: [id])
  productId    String
  quantity     Int
  sellingPrice Float
  customer     String
  totalRevenue Float
  profit       Float
  date         DateTime @default(now())
}

model RateHistory {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  price     Float
  date      DateTime @default(now())
}